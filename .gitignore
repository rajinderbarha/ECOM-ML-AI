# Ignore node_modules folder (for both the app and server)
node_modules/

# Ignore build directories for Next.js (you don't want to push these)
.next/
out/

# Ignore environment variables (sensitive data)
.env
.env.local
.env.development
.env.production
.env.test

# Ignore log files
npm-debug.log
yarn-debug.log
yarn-error.log

# Ignore operating system specific files (macOS, Windows, etc.)
.DS_Store

# Ignore IDE/editor-specific files
.vscode/
.idea/
*.swp
